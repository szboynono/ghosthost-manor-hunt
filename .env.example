# Discord Activity Client ID
# Get yours at https://discord.com/developers/applications (Embedded Activity feature)
# Leave unset (or omit this file entirely) to run in local browser mode.
VITE_DISCORD_CLIENT_ID=

# Phase C — Session server
# URL of the WebSocket session server (npm run dev:server).
# Leave unset to skip shared session (local single-player mode).
VITE_SESSION_SERVER_URL=ws://localhost:3001

# Dev instance ID — used when Discord SDK is absent and no ?instanceId= URL param is present.
# Set this to test multi-tab session sync locally (open two tabs with the same value).
VITE_DEV_INSTANCE_ID=dev-room
